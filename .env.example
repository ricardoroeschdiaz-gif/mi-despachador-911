# --- Base de Datos PostgreSQL (usado por FastAPI y Compose) ---
DATABASE_URL=postgresql://dispatch_user:dispatch_pass@db:5432/dispatch_db

# --- API Keys (Para Gemini y lógica AI) ---
GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# --- FCM (Firebase Cloud Messaging) ---
FIREBASE_CREDENTIALS_PATH=/app/app/config/tu_archivo_firebase.json

# --- Otras Variables de Configuración ---
ENV_MODE=production
SECRET_KEY=cambiar_esta_llave_en_produccion